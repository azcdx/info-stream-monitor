{
  "manifest_version": 3,
  "name": "信息流监控助手",
  "version": "2.0.0",
  "description": "监控金十数据、Reddit，AI 分析价值并推送",
  "permissions": [
    "storage",
    "sidePanel"
  ],
  "host_permissions": [
    "https://*.jin10.com/*",
    "https://*.reddit.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {},
  "side_panel": {
    "default_path": "sidepanel.html"
  }
}
